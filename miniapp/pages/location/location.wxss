page {
  background: #f0f2f5;
}

.page {
  min-height: 100vh;
  background: #f0f2f5;
}

/* 顶部渐变区 */
.page-header {
  background: linear-gradient(160deg, #0f2544 0%, #1a3f6f 55%, #1e5799 100%);
  padding: 60rpx 32rpx 48rpx;
  position: relative;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  margin-bottom: 40rpx;
}

/* 位置统计行 */
.location-info-row {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 28rpx 0;
}

.location-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.location-stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
}

.location-stat-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.location-stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
}

/* 地图 */
.map-wrap {
  width: 100%;
  height: 460rpx;
  position: relative;
}

.track-map {
  width: 100%;
  height: 100%;
}

/* 内容区 */
.content-area {
  padding: 24rpx 0 60rpx;
}

/* 最后定位卡片 */
.last-location-card {
  margin-bottom: 20rpx;
}

.last-location-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.last-location-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: rgba(52, 199, 89, 0.1);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.last-location-icon {
  font-size: 44rpx;
}

.last-location-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.last-location-label {
  font-size: 22rpx;
  color: #8a9bb0;
}

.last-location-time {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2233;
}

.last-location-coord {
  font-size: 22rpx;
  color: #8a9bb0;
  font-family: 'Courier New', monospace;
}

/* 空状态 */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.35;
}

.empty-text {
  font-size: 26rpx;
  color: #b0bcc8;
}

/* 轨迹时间线 */
.record-row {
  display: flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.timeline-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 24rpx;
  padding-top: 6rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c8d0da;
  flex-shrink: 0;
}

.dot-first {
  background: #34c759;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.2);
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  min-height: 40rpx;
  background: #edf0f4;
  margin-top: 6rpx;
}

.record-content {
  flex: 1;
  padding-bottom: 28rpx;
}

.record-time {
  display: block;
  font-size: 24rpx;
  color: #8a9bb0;
  margin-bottom: 8rpx;
}

.record-coord {
  display: block;
  font-size: 26rpx;
  color: #3a4a5c;
  font-family: 'Courier New', monospace;
}
