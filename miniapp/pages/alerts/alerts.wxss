page {
  background: #f0f2f5;
}

.page {
  min-height: 100vh;
  background: #f0f2f5;
}

.page-header {
  background: linear-gradient(160deg, #3a1720 0%, #8f2634 58%, #c94a3b 100%);
  padding: 60rpx 32rpx 96rpx;
  position: relative;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 0;
  right: 0;
  height: 50rpx;
  background: #f0f2f5;
  border-radius: 40rpx 40rpx 0 0;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.62);
}

.content-area {
  padding: 28rpx 0 60rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
}

.empty-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(52, 199, 89, 0.12);
  color: #34c759;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  margin-bottom: 18rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #8a9bb0;
}

.alert-card {
  padding: 30rpx 32rpx;
}

.alert-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.alert-badge {
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  background: rgba(231, 76, 60, 0.1);
  color: #d63f32;
  font-size: 24rpx;
  font-weight: 700;
}

.alert-time {
  font-size: 24rpx;
  color: #8a9bb0;
}

.alert-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.alert-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2233;
}

.alert-location {
  font-size: 26rpx;
  color: #3a4a5c;
  font-family: 'Courier New', monospace;
}

.gps-valid,
.gps-invalid {
  font-size: 24rpx;
}

.gps-valid {
  color: #34c759;
}

.gps-invalid {
  color: #e67e22;
}

.location-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  background: #304156;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.location-btn[disabled] {
  background: #c8d0da;
  color: #fff;
}
