page {
  background: #f0f2f5;
}

.page {
  min-height: 100vh;
  background: #f0f2f5;
}

/* 顶部渐变区 */
.page-header {
  background: linear-gradient(160deg, #0f2544 0%, #1a3f6f 55%, #1e5799 100%);
  padding: 60rpx 32rpx 120rpx;
  position: relative;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 0;
  right: 0;
  height: 50rpx;
  background: #f0f2f5;
  border-radius: 40rpx 40rpx 0 0;
}

.header-top {
  margin-bottom: 48rpx;
}

.device-name-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.device-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.device-model {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  margin-bottom: 8rpx;
}

.last-heartbeat {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

/* 头部统计行 */
.header-stats {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 32rpx 0;
}

.header-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.2);
}

.stat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.battery-icon-wrap {
  background: rgba(52, 199, 89, 0.2);
}

.steps-icon-wrap {
  background: rgba(90, 160, 255, 0.2);
}

.stat-icon {
  font-size: 34rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
}

/* 内容区 */
.content-area {
  padding: 28rpx 0 60rpx;
}

/* 健康卡片 */
.health-card {
  margin-bottom: 20rpx;
}

.card-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.card-header-row .section-title {
  margin-bottom: 0;
}

.measured-at {
  font-size: 22rpx;
  color: #8a9bb0;
}

/* 健康指标环形展示 */
.health-metrics {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.metric-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 6rpx solid;
}

.heart-ring {
  border-color: #ff4d6a;
  background: rgba(255, 77, 106, 0.06);
}

.bp-ring {
  border-color: #5a9fff;
  background: rgba(90, 159, 255, 0.06);
}

.temp-ring {
  border-color: #ff9f40;
  background: rgba(255, 159, 64, 0.06);
}

.metric-main-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a2233;
}

.metric-bp-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a2233;
  line-height: 1.2;
}

.metric-bp-sep {
  font-size: 22rpx;
  color: #8a9bb0;
}

.metric-label {
  font-size: 24rpx;
  color: #8a9bb0;
}

.metric-unit {
  font-size: 20rpx;
  color: #b0bcc8;
  margin-top: -8rpx;
}

/* 空状态健康卡片 */
.empty-health-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  margin-bottom: 20rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.35;
}

.empty-text {
  font-size: 26rpx;
  color: #b0bcc8;
}

/* 位置卡片 */
.location-card {
  margin-bottom: 20rpx;
}

.location-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.location-pin {
  width: 72rpx;
  height: 72rpx;
  background: rgba(52, 199, 89, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.location-pin-icon {
  font-size: 36rpx;
}

.location-coords {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.coord-text {
  font-size: 26rpx;
  color: #3a4a5c;
  font-family: 'Courier New', monospace;
}

/* 导航格子 */
.nav-grid {
  display: flex;
  gap: 20rpx;
  padding: 0 24rpx;
  margin-top: 4rpx;
}

.nav-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.nav-card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.health-nav-icon {
  background: rgba(255, 77, 106, 0.1);
}

.location-nav-icon {
  background: rgba(52, 199, 89, 0.1);
}

.nav-card-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2233;
}

.nav-card-sub {
  font-size: 22rpx;
  color: #8a9bb0;
}

/* 名字编辑态 */
.edit-icon {
  font-size: 28rpx;
  opacity: 0.7;
  padding: 4rpx 8rpx;
}

.name-input {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  border-bottom: 2rpx solid rgba(255,255,255,0.6);
  padding-bottom: 4rpx;
  min-width: 200rpx;
  max-width: 340rpx;
}

.confirm-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  background: rgba(52,199,89,0.5);
  border-radius: 12rpx;
  margin-left: 12rpx;
}

.confirm-btn-disabled {
  opacity: 0.35;
}
