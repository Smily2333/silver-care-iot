page {
  background: #f0f2f5;
}

.page {
  min-height: 100vh;
  background: #f0f2f5;
}

/* 顶部渐变区 */
.page-header {
  background: linear-gradient(160deg, #0f2544 0%, #1a3f6f 55%, #1e5799 100%);
  padding: 60rpx 32rpx 120rpx;
  position: relative;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 0;
  right: 0;
  height: 50rpx;
  background: #f0f2f5;
  border-radius: 40rpx 40rpx 0 0;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  margin-bottom: 48rpx;
}

/* 最新数据大展示 */
.latest-metrics {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.metric-big-item {
  flex: 1;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.heart-item {
  background: rgba(255, 77, 106, 0.18);
  border: 1rpx solid rgba(255, 77, 106, 0.3);
}

.bp-item {
  background: rgba(90, 159, 255, 0.18);
  border: 1rpx solid rgba(90, 159, 255, 0.3);
}

.temp-item {
  background: rgba(255, 159, 64, 0.18);
  border: 1rpx solid rgba(255, 159, 64, 0.3);
}

.metric-big-icon {
  font-size: 36rpx;
}

.metric-big-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.1;
}

.bp-val {
  font-size: 28rpx !important;
}

.metric-big-unit {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  text-align: center;
}

/* 内容区 */
.content-area {
  padding: 28rpx 0 60rpx;
}

/* 历史记录 */
.empty-tip {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #b0bcc8;
}

.record-row {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
}

.record-row:last-child {
  border-bottom: none;
}

.record-time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.record-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #34c759;
  flex-shrink: 0;
}

.record-time {
  font-size: 24rpx;
  color: #8a9bb0;
}

.record-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-left: 24rpx;
}

.record-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.heart-tag {
  background: rgba(255, 77, 106, 0.08);
  color: #ff4d6a;
}

.bp-tag {
  background: rgba(90, 159, 255, 0.08);
  color: #5a9fff;
}

.temp-tag {
  background: rgba(255, 159, 64, 0.08);
  color: #ff9f40;
}

.tag-icon {
  font-size: 20rpx;
}
