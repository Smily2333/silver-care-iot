<!--首页：输入设备编号-->
<view class="page">
  <!-- 顶部渐变区域 -->
  <view class="page-header">
    <view class="header-content">
      <view class="brand-row">
        <view class="brand-icon">❤</view>
        <view class="brand-info">
          <text class="brand-name">Silver Care</text>
          <text class="brand-sub">老人健康守护平台</text>
        </view>
      </view>
      <!-- 搜索框 -->
      <view class="search-wrap">
        <view class="search-icon-wrap">
          <text class="search-icon">🔍</text>
        </view>
        <input
          class="search-input"
          placeholder="输入设备编号"
          placeholder-class="search-placeholder"
          value="{{deviceNo}}"
          bindinput="onInput"
          bindconfirm="onQuery"
          confirm-type="search"
        />
        <view class="search-btn" bindtap="onQuery">
          <text class="search-btn-text" wx:if="{{!loading}}">查询</text>
          <text class="search-btn-text" wx:else>...</text>
        </view>
      </view>
      <text class="error-msg" wx:if="{{errorMsg}}">⚠ {{errorMsg}}</text>
    </view>
  </view>

  <!-- 内容区 -->
  <view class="content-area">
    <!-- 快速入口 -->
    <view class="quick-title" wx:if="{{recentList.length === 0}}">
      <text class="hint-text">输入设备编号开始监护</text>
    </view>

    <!-- 最近查看 -->
    <view wx:if="{{recentList.length > 0}}" class="recent-section">
      <text class="section-title">最近查看</text>
      <view class="recent-list">
        <view
          wx:for="{{recentList}}"
          wx:key="deviceNo"
          class="recent-item"
          bindtap="onRecentTap"
          data-no="{{item.deviceNo}}"
        >
          <view class="recent-avatar">
            <text class="recent-avatar-text">{{item.displayInitial}}</text>
          </view>
          <view class="recent-info">
            <text class="recent-no">{{item.displayName}}</text>
            <text class="recent-hint">点击查看详情</text>
          </view>
          <view class="recent-arrow-wrap">
            <text class="recent-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="footer-tip">
      <text class="footer-tip-text">实时监测 · 健康守护</text>
    </view>
  </view>
</view>
