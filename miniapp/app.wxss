/* 全局样式 - 荣耀健康风格 */
page {
  background-color: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

/* 标签文字 */
.label {
  font-size: 24rpx;
  color: #8a9bb0;
  margin-bottom: 6rpx;
}

/* 数值 */
.value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a2233;
  line-height: 1.1;
}

/* 在线/离线标签 */
.tag-online {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  background: rgba(52, 199, 89, 0.12);
  color: #34c759;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-offline {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  background: rgba(142, 142, 147, 0.12);
  color: #8e8e93;
  font-size: 22rpx;
  font-weight: 600;
}

/* 渐变顶部背景 */
.page-header {
  background: linear-gradient(160deg, #0f2544 0%, #1a3f6f 50%, #1e5799 100%);
  padding: 60rpx 32rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: 0;
  right: 0;
  height: 80rpx;
  background: #f0f2f5;
  border-radius: 40rpx 40rpx 0 0;
}

/* 通用 section 标题 */
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2233;
  margin-bottom: 24rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 500rpx;
  color: #8a9bb0;
  font-size: 28rpx;
}
